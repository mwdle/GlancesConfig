{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>lab/renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/*.yaml", "**/*.yml"],
      "matchStrings": ["glances_version:\\s+(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "glances",
      "datasourceTemplate": "pypi"
    }
  ]
}
